---
interface Props {
  tag?: string;
  title: string;
  description?: string;
}

const { tag, title, description } = Astro.props;
---

<div class="container mt-12">
  <div class="flex relative rounded-md overflow-hidden bg-blue-400">
    <img
      src="/hero-movie.jpg"
      alt={title}
      class="grayscale mix-blend-multiply w-full object-cover"
      style="height: 280px;"
      transition:name="hero-image"
    />

    <div
      class="absolute inset-0"
      style="background-image: linear-gradient(to bottom, rgba(49, 130, 206, 0) 24%, rgba(49, 130, 206, .5) 100%);"
    >
    </div>

    {
      tag && (
        <span class="absolute top-0 right-0 bg-blue-700 text-sm text-white font-medium px-3 py-1 rounded-lg m-4 tracking-wide">
          {tag}
        </span>
      )
    }

    <div class="absolute bottom-0 inset-x-0 p-5 lg:p-6 text-white">
      <h1 class="text-2xl lg:text-4xl font-bold leading-tight">{title}</h1>
      {description && <h3 class="text-lg font-medium md:w-2/3">{description}</h3>}
    </div>
  </div>
</div>
