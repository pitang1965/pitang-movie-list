---
import type { Movie } from "../lib/airtable";
import Card from "./Card.astro";

interface Props {
  movies: Movie[];
}

const { movies } = Astro.props;
---

<div class="container pt-6 overflow-hidden">
  <div class="flex flex-wrap -mx-3 xl:-mx-6">
    {
      movies.map((movie) => (
        <div class="w-full sm:w-1/2 xl:w-1/3 px-3 xl:px-6 py-6">
          <Card movie={movie} />
        </div>
      ))
    }
  </div>
</div>
