---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 - ページが見つかりません">
  <div class="container py-20 text-center">
    <h1 class="text-4xl font-bold text-blue-500 mb-4">404</h1>
    <p class="text-lg text-blue-800 mb-8">ページが見つかりませんでした。</p>
    <a
      href="/"
      class="inline-block bg-blue-500 hover:bg-blue-600 text-white font-medium px-6 py-3 rounded-md transition-colors duration-200"
    >
      トップへ戻る
    </a>
  </div>
</Layout>
